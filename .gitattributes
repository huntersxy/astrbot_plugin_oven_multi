# Auto detect text files and perform LF normalization
* text=auto

# Force LF for source files
*.py text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary

# Exclude from release zip (git archive)
.trae/ export-ignore
参考资料/ export-ignore
.gitattributes export-ignore
.gitignore export-ignore
CHANGELOG.md export-ignore
